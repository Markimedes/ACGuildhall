# Copy to .env (gitignored) for docker-compose. These map to GUILDHALL_* env vars
# read by app.load_config(). All config comes from these variables -- there is no
# config file.

# Flask signing key. Generate: python -c "import secrets; print(secrets.token_hex(32))"
GUILDHALL_SECRET_KEY=REPLACE_WITH_RANDOM_HEX

# Behind nginx terminating TLS: set both true so Secure cookies are issued and the
# real client IP / https scheme are honored (ProxyFix trusts one proxy hop).
GUILDHALL_BEHIND_TLS=true
GUILDHALL_TRUST_PROXY=true

# Host's natively-running MySQL, reached via the host-gateway mapping in compose.
GUILDHALL_DB_HOST=host.docker.internal
GUILDHALL_DB_PORT=3306
GUILDHALL_DB_USER=guildhall
GUILDHALL_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GUILDHALL_DB_POOL_SIZE=5

# Invite-link self-registration.
GUILDHALL_INVITE_TOKENS_DEFAULT=3
GUILDHALL_INVITE_TTL_HOURS=12
GUILDHALL_NEW_ACCOUNT_EXPANSION=2
GUILDHALL_ADMIN_GMLEVEL=3
# Public URL players use to reach the panel (used for invite links). Behind nginx,
# set this to your domain, e.g. https://guildhall.example.com
GUILDHALL_PUBLIC_BASE_URL=
# How long to cache each profile's "in-demand resources" before recomputing.
GUILDHALL_DEMAND_REFRESH_MINUTES=360

# AHPricingService -- the realm's sole AH pricing authority. The Auction House
# tab gets every price from here (no local pricing). Reachable by container name on
# the shared 'edge' network; if unreachable, items just show as "Not priced".
GUILDHALL_AHPRICING_URL=http://ahpricingservice:8089/price
GUILDHALL_AHPRICING_TIMEOUT=1.5

# Worldserver SOAP -- lets players list items on the AH from the panel (and is a
# reusable console-command channel). Leave URL empty to disable the "sell" feature.
# Needs SOAP.Enabled=1 in worldserver.conf, bound to an address the container can
# reach (host-gateway here), and an account with gmlevel 3 (SEC_ADMINISTRATOR).
# WARNING: this account can run ANY server command -- keep these secrets safe and
# firewall the SOAP port off the public internet.
# Pick a SOAP.Port that's actually free on the host: 7878 (AzerothCore's default)
# collides with Radarr, so this realm uses 7880 -- match SOAP.Port in worldserver.conf.
GUILDHALL_SOAP_URL=http://host.docker.internal:7880/
GUILDHALL_SOAP_USER=GUILDHALL_SOAP
GUILDHALL_SOAP_PASS=CHANGE_ME_STRONG_PASSWORD
GUILDHALL_SOAP_TIMEOUT=5
# Auction deposit *preview* only (server charges the exact amount). Match these to
# the realm: AuctionHouse.dbc deposit (5 = faction AH) and Rate.Auction.Deposit.
GUILDHALL_AH_DEPOSIT_PERCENT=5
GUILDHALL_AH_DEPOSIT_RATE=1.0
# Min seconds between a player's "Refresh inventory" force-saves (per character).
GUILDHALL_AH_REFRESH_SECONDS=60

# Shared downloads. The app lists files in this dir (mount it into the container,
# read-only -- see docker-compose.yml). For real downloads behind nginx, set the
# internal-prefix to the matching "internal" location so nginx streams the bytes
# via X-Accel-Redirect instead of Flask (see deploy/nginx.guildhall.conf).
GUILDHALL_DOWNLOADS_DIR=/media/plex/downloads
GUILDHALL_DOWNLOADS_INTERNAL_PREFIX=/protected-downloads

# AI news desk -- generates in-universe newspaper articles about market shifts and
# player exploits (Google AI Studio / Gemini). Leave the key empty to disable: the
# news desk stays dark and the rest of the app is unaffected. Requires google-genai
# (see requirements.txt). Keep the key secret -- it bills your AI Studio account.
GUILDHALL_GEMINI_API_KEY=
GUILDHALL_GEMINI_MODEL=gemini-3-flash-preview
GUILDHALL_GEMINI_THINKING=HIGH
GUILDHALL_GEMINI_TIMEOUT=30

# News desk daily schedule (the news-scheduler sidecar). It generates the edition
# once at this time each day, just after the AHPricingService rolls the new market
# event at midnight. Times are CONTAINER-LOCAL -- set TZ so the container's midnight
# matches the pricing service's, or the paper may be written for the wrong day.
TZ=UTC
GUILDHALL_NEWS_HOUR=0
GUILDHALL_NEWS_MINUTE=5
# If a generation pass comes out incomplete (e.g. a transient Gemini 503/504), the
# scheduler retries this often until the edition is complete, rather than waiting a
# full day. Only the missing stories are regenerated (cache-first). It gives up
# after MAX_RETRIES attempts and waits for the next daily run.
GUILDHALL_NEWS_RETRY_SECONDS=300
GUILDHALL_NEWS_MAX_RETRIES=20

# Heroic Exploits (player achievements + quest completion stories). The scheduler
# picks the day's noteworthy characters -- milestones first, then top achievement
# earners -- and writes up to EXPLOITS_MAX stories (each one Gemini call). Quests
# finished by several characters the same day merge into one story. WINDOW_HOURS is
# how far back a first-seen character's achievements count; MILESTONE_POINTS is the
# achievement-points threshold that marks a "milestone" moment.
GUILDHALL_EXPLOITS_MAX=4
GUILDHALL_EXPLOITS_WINDOW_HOURS=24
GUILDHALL_EXPLOITS_MILESTONE_POINTS=20
